{
  "extensions": [
    "~/.pi/agent/extensions/llama-cpp.ts",
    "~/.pi/agent/extensions/pi-chat-link.ts",
    "~/.pi/agent/extensions/peer-model.ts"
  ],
  "defaultProvider": "llama-cpp",
  "defaultModel": "qwen3.5-27b-q4km",
